// ═══════════════════════════════════════════════════════
// DISRUPTIO — Prisma Schema
// ═══════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Company ───────────────────────────────────────────

model Company {
  id          String   @id @default(uuid())
  name        String
  email       String?
  plan        String   @default("starter")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     String? // Company website URL for web context seeding
  linkedinUrl String? // LinkedIn company page URL
  webContext  String? // AI-extracted and summarised company context from web
  language    String   @default("en") // en | pt-PT | fr

  users                     User[]
  documents                 Document[]
  docFolders                DocFolder[]
  documentEmbeddings        DocumentEmbedding[]
  diagnosticAssessments     DiagnosticAssessment[]
  useCases                  UseCase[]
  dataQualityJobs           DataQualityJob[]
  governanceTemplates       GovernanceTemplate[]
  workflows                 Workflow[]
  usageMetrics              UsageMetric[]
  supportTickets            SupportTicket[]
  conversations             Conversation[]
  features                  CompanyFeature[]
  license                   License?
  classificationTypes       ClassificationType[]
  classificationResults     ClassificationResult[]
  classificationHistory     ClassificationHistory[]
  companyProfile            CompanyProfile?
  onboardingGuide           CompanyOnboardingGuide?
  leadSearchRuns            LeadSearchRun[]
  leadResults               LeadResult[]
  leadLists                 LeadList[]
  marketingRuns             MarketingGenerationRun[]
  marketingDrafts           MarketingDraft[]
  salesRuns                 SalesGenerationRun[]
  salesDrafts               SalesDraft[]
  productRuns               ProductGenerationRun[]
  productDrafts             ProductDraft[]
  onboardingAssistantRuns   OnboardingGenerationRun[]
  onboardingAssistantDrafts OnboardingDraft[]
  advisorRuns               AdvisorGenerationRun[]
  advisorDrafts             AdvisorDraft[]
  generalAIRuns             GeneralAIGenerationRun[]
  generalAIDrafts           GeneralAIDraft[]
  onboardingState           CompanyOnboardingState?
  brainProfiles             AIBrainProfile[]
  brainTestRuns             AIBrainTestRun[]
  projects                  Project[]
  taskBoards                TaskBoard[]
  tasks                     Task[]
  accessGroups              AccessGroup[]
  accessGroupMemberships    AccessGroupMembership[]
  accessPermissionGrants    AccessPermissionGrant[]
  crmLeads                  CrmLead[]
  crmPipelineStages         CrmPipelineStage[]
  assistantSkills            AssistantSkill[]
  apiKeys                    CompanyApiKey[]
  integrations               CompanyIntegration[]
  externalActions            ExternalAction[]
  externalDocuments          ExternalDocument[]
  customers                  Customer[]
  companyDNA                 CompanyDNA?
  knowledgeNodes             KnowledgeNode[]
  resources                  Resource[]
  feedbackEvents             FeedbackEvent[]
  initiatives                Initiative[]
  planDrafts                 PlanDraft[]
  virtualOffice              VirtualOffice?
  dailyBriefs                DailyBrief[]
}

// ─── Company API Keys ─────────────────────────────────

model CompanyApiKey {
  id         String    @id @default(uuid())
  companyId  String
  label      String    // e.g. "MOBY Website Contact Form"
  keyHash    String    @unique // SHA-256 hash of the full API key
  keyPrefix  String    // First 8 chars for display: "nk_a1b2c3d4••••"
  scopes     String[]  // e.g. ["crm:leads:write"]
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([keyHash])
}

// ─── Company Integrations ─────────────────────────────

model CompanyIntegration {
  id              String    @id @default(uuid())
  companyId       String
  provider        String    // ZAPIER_MCP | GOOGLE_DRIVE | NOTION | SHAREPOINT
  label           String    @default("Integration") // Display name
  config          Json      @default("{}") // { mcpEndpointUrl, selectedFolders, ... }
  oauthTokens     Json?     // Encrypted OAuth2 tokens { accessToken, refreshToken, expiresAt }
  isActive        Boolean   @default(true)
  syncFrequency   String    @default("6h") // 1h | 6h | 12h | 24h | manual
  lastSyncedAt    DateTime?
  lastSyncStatus  String?   // SUCCESS | PARTIAL | FAILED
  actionCount     Int       @default(0) // Zapier: action count. Drive: file count.
  errorLog        String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  externalActions   ExternalAction[]
  externalDocuments ExternalDocument[]

  @@unique([companyId, provider])
  @@index([companyId])
}

// ─── External Actions (Tool Catalog) ──────────────────

model ExternalAction {
  id              String    @id @default(uuid())
  companyId       String
  integrationId   String
  name            String    // "Send Email"
  description     String?   @db.Text
  toolName        String    // MCP tool name from Zapier
  serviceApp      String    // "Gmail", "Google Sheets", "Slack"
  inputSchema     Json?     // Parameter schema from MCP
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration CompanyIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([companyId, toolName])
  @@index([companyId])
  @@index([integrationId])
}

// ─── Customer (External Client) ───────────────────────

model Customer {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  description   String?  @db.Text
  industry      String?
  website       String?
  contactName   String?
  contactEmail  String?
  contextText   String?  @db.Text   // AI-extracted customer context
  status        String   @default("active") // active | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([companyId])
  @@unique([companyId, name])
}

// ─── Project (Client/Workspace) ───────────────────────

model Project {
  id          String   @id @default(uuid())
  companyId   String
  customerId  String?
  name        String
  description String?  @db.Text
  contextText String?  @db.Text
  status      String   @default("active") // active | completed | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  documents  Document[]  @relation("ProjectDocuments")
  taskBoards TaskBoard[]
  initiatives Initiative[]

  @@index([companyId])
  @@index([customerId])
}

// ─── Company Feature (Backoffice FR-5, FR-6) ──────────

model CompanyFeature {
  id         String   @id @default(uuid())
  companyId  String
  featureKey String // e.g., "documents", "ocr", "search", "diagnostics", etc.
  enabled    Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureKey])
  @@index([companyId])
}

// ─── License (Backoffice FR-7, FR-8, FR-9) ────────────

model License {
  id        String    @id @default(uuid())
  companyId String    @unique
  plan      String    @default("starter")
  startsAt  DateTime  @default(now())
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── User ──────────────────────────────────────────────

enum UserRole {
  MEMBER
  ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

model User {
  id            String       @id @default(uuid())
  companyId     String
  name          String
  email         String       @unique
  role          UserRole     @default(MEMBER)
  authProvider  AuthProvider @default(EMAIL)
  avatarUrl     String?
  timezone      String       @default("Europe/Lisbon")
  status        String       @default("ACTIVE") // ACTIVE | INACTIVE | PENDING
  deactivatedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime?    @updatedAt

  // ── Onboarding fields ──
  mustChangePassword   Boolean   @default(false)
  isProvisionedByAdmin Boolean   @default(false)
  inviteSentAt         DateTime?
  passwordChangedAt    DateTime?
  firstLoginAt         DateTime?

  company                       Company                   @relation(fields: [companyId], references: [id])
  uploadedDocs                  Document[]                @relation("DocumentUploader")
  diagnosticAssessments         DiagnosticAssessment[]
  dataQualityJobs               DataQualityJob[]
  workflows                     Workflow[]                @relation("WorkflowCreator")
  workflowRuns                  WorkflowRun[]
  usageMetrics                  UsageMetric[]
  supportTickets                SupportTicket[]
  conversations                 Conversation[]            @relation("ConversationCreator")
  classificationTypes           ClassificationType[]      @relation("ClassificationTypeCreator")
  classificationHistory         ClassificationHistory[]   @relation("ClassificationHistoryUser")
  leadSearchRuns                LeadSearchRun[]           @relation("LeadSearchRunCreator")
  leadLists                     LeadList[]                @relation("LeadListCreator")
  marketingRuns                 MarketingGenerationRun[]  @relation("MarketingRunCreator")
  marketingDrafts               MarketingDraft[]          @relation("MarketingDraftCreator")
  salesRuns                     SalesGenerationRun[]      @relation("SalesRunCreator")
  salesDrafts                   SalesDraft[]              @relation("SalesDraftCreator")
  productRuns                   ProductGenerationRun[]    @relation("ProductRunCreator")
  productDrafts                 ProductDraft[]            @relation("ProductDraftCreator")
  onboardingAssistantRuns       OnboardingGenerationRun[] @relation("OnboardingRunCreator")
  onboardingAssistantDrafts     OnboardingDraft[]         @relation("OnboardingDraftCreator")
  advisorRuns                   AdvisorGenerationRun[]    @relation("AdvisorRunCreator")
  advisorDrafts                 AdvisorDraft[]            @relation("AdvisorDraftCreator")
  generalAIRuns                 GeneralAIGenerationRun[]  @relation("GeneralAIRunCreator")
  generalAIDrafts               GeneralAIDraft[]          @relation("GeneralAIDraftCreator")
  brainProfilesCreated          AIBrainProfile[]          @relation("BrainProfileCreator")
  brainProfilesUpdated          AIBrainProfile[]          @relation("BrainProfileUpdater")
  brainVersions                 AIBrainVersion[]          @relation("BrainVersionCreator")
  brainTestRuns                 AIBrainTestRun[]          @relation("BrainTestRunCreator")
  taskBoardsCreated             TaskBoard[]               @relation("TaskBoardCreator")
  tasksAssigned                 Task[]                    @relation("TaskAssignee")
  tasksReported                 Task[]                    @relation("TaskReporter")
  taskComments                  TaskComment[]             @relation("TaskCommenter")
  taskActivities                TaskActivity[]            @relation("TaskActivityActor")
  // Access group relations
  accessGroupMemberships        AccessGroupMembership[]   @relation("MembershipUser")
  accessGroupMembershipsCreated AccessGroupMembership[]   @relation("MembershipCreator")
  accessGroupsCreated           AccessGroup[]             @relation("AccessGroupCreator")
  accessGroupsUpdated           AccessGroup[]             @relation("AccessGroupUpdater")
  // CRM relations
  crmLeadsOwned                 CrmLead[]                 @relation("CrmLeadOwner")
  crmLeadsCreated               CrmLead[]                 @relation("CrmLeadCreator")
  crmLeadActivities             CrmLeadActivity[]         @relation("CrmActivityActor")
  dailyBriefs                   DailyBrief[]

  @@index([companyId])
}

// ─── Access Group ─────────────────────────────────────

model AccessGroup {
  id              String    @id @default(uuid())
  companyId       String
  name            String
  description     String?   @db.Text
  isSystemManaged Boolean   @default(false)
  createdById     String?
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now())
  archivedAt      DateTime?

  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User?                   @relation("AccessGroupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?                   @relation("AccessGroupUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  memberships AccessGroupMembership[]
  grants      AccessPermissionGrant[]

  @@unique([companyId, name])
  @@index([companyId])
}

// ─── Access Group Membership ──────────────────────────

model AccessGroupMembership {
  id            String   @id @default(uuid())
  companyId     String
  accessGroupId String
  userId        String
  createdAt     DateTime @default(now())
  createdById   String?

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accessGroup AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)
  user        User        @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("MembershipCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([accessGroupId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([accessGroupId])
}

// ─── Access Permission Grant ──────────────────────────

model AccessPermissionGrant {
  id            String   @id @default(uuid())
  companyId     String
  accessGroupId String
  resourceType  String // 'FEATURE' | 'SUB_FEATURE' | 'PROJECT_SCOPE'
  resourceKey   String // e.g. 'marketing', 'documents.upload', 'project:<id>'
  accessLevel   String   @default("USE") // 'VIEW' | 'USE' | 'MANAGE'
  createdAt     DateTime @default(now())

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accessGroup AccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)

  @@unique([accessGroupId, resourceType, resourceKey])
  @@index([companyId])
  @@index([accessGroupId])
}

// ─── Company Onboarding State ─────────────────────────

model CompanyOnboardingState {
  id             String    @id @default(uuid())
  companyId      String    @unique
  primaryUserId  String
  status         String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED
  currentStep    Int       @default(1)
  completedSteps Json? // e.g. [1, 2, 3]
  stepDrafts     Json? // e.g. { "2": {...}, "3": {...} }
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ─── Document ──────────────────────────────────────────

model Document {
  id                   String   @id @default(uuid())
  companyId            String
  folderId             String?
  filename             String
  mimeType             String
  size                 Int
  storageKey           String
  uploadedById         String
  extractedText        String?  @db.Text
  ocrProcessed         Boolean  @default(false)
  ocrStatus            String   @default("PENDING") // PENDING | PROCESSING | PROCESSED | ERROR
  ocrError             String?  @db.Text
  version              Int      @default(1)
  knowledgeCategory    String?
  useAsKnowledgeSource Boolean  @default(false)
  knowledgePriority    String?  @default("normal")
  language             String?
  hash                 String?
  projectId            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company               Company                @relation(fields: [companyId], references: [id])
  folder                DocFolder?             @relation(fields: [folderId], references: [id])
  project               Project?               @relation("ProjectDocuments", fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy            User                   @relation("DocumentUploader", fields: [uploadedById], references: [id])
  embeddings            DocumentEmbedding[]
  classificationResults ClassificationResult[]
  taskDocuments         TaskDocument[]

  @@index([companyId, createdAt])
  @@index([folderId])
  @@index([projectId])
}

// ─── Document Folder ───────────────────────────────────

model DocFolder {
  id        String   @id @default(uuid())
  companyId String
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  company   Company     @relation(fields: [companyId], references: [id])
  parent    DocFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocFolder[] @relation("FolderTree")
  documents Document[]

  @@index([companyId, parentId])
}

// ─── Document Embedding (pgvector) ─────────────────────

model DocumentEmbedding {
  id                 String  @id @default(uuid())
  companyId          String
  documentId         String
  externalDocumentId String?
  chunkIndex         Int
  chunkText          String  @db.Text
  embedding          String  @db.Text // Stored as JSON; pgvector column created via raw migration

  company          Company           @relation(fields: [companyId], references: [id])
  document         Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  externalDocument ExternalDocument? @relation(fields: [externalDocumentId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([documentId])
  @@index([externalDocumentId])
}

// ─── External Document (Synced from Providers) ─────────

model ExternalDocument {
  id                   String    @id @default(uuid())
  companyId            String
  integrationId        String
  externalId           String    // Google Drive fileId, Notion pageId, etc.
  externalUrl          String?   // Direct link to source
  filename             String
  mimeType             String?
  size                 Int?
  externalPath         String?   // /folder/subfolder/file.pdf
  extractedText        String?   @db.Text
  contentHash          String?   // SHA-256 of content — skip re-processing if unchanged
  lastExternalMod      DateTime?
  syncStatus           String    @default("PENDING") // PENDING | SYNCED | CHANGED | DELETED | ERROR
  knowledgeCategory    String?
  useAsKnowledgeSource Boolean   @default(true)
  knowledgePriority    String?   @default("normal")
  language             String?
  projectId            String?
  ocrProcessed         Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration CompanyIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  embeddings  DocumentEmbedding[]

  @@unique([integrationId, externalId])
  @@index([companyId])
  @@index([integrationId, syncStatus])
}

// ─── Diagnostic Assessment (FR-8, FR-9) ────────────────

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
}

model DiagnosticAssessment {
  id        String           @id @default(uuid())
  userId    String
  companyId String
  answers   Json
  score     Float?
  report    String?          @db.Text
  status    AssessmentStatus @default(IN_PROGRESS)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
}

// ─── Use Case (FR-10, FR-11) ───────────────────────────

model UseCase {
  id           String   @id @default(uuid())
  companyId    String?
  industry     String
  title        String
  summary      String   @db.Text
  challenge    String?  @db.Text
  solution     String?  @db.Text
  results      String?  @db.Text
  caseStudyUrl String?
  isGlobal     Boolean  @default(false)
  createdAt    DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])

  @@index([industry])
}

// ─── Data Quality Job (FR-12, FR-13) ───────────────────

enum DataQualityStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model DataQualityJob {
  id          String            @id @default(uuid())
  companyId   String
  userId      String
  sourceType  String
  sourceName  String
  metrics     Json?
  status      DataQualityStatus @default(PENDING)
  report      String?           @db.Text
  createdAt   DateTime          @default(now())
  completedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
}

// ─── Governance Template (FR-14, FR-15) ────────────────

model GovernanceTemplate {
  id        String   @id @default(uuid())
  companyId String?
  name      String
  category  String
  content   String   @db.Text
  isGlobal  Boolean  @default(false)
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@index([category])
}

// ─── Workflow / Automation (FR-16) ─────────────────────

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model Workflow {
  id          String         @id @default(uuid())
  companyId   String
  createdById String
  name        String
  description String?
  trigger     String?
  steps       Json
  status      WorkflowStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company       @relation(fields: [companyId], references: [id])
  createdBy User          @relation("WorkflowCreator", fields: [createdById], references: [id])
  runs      WorkflowRun[]

  @@index([companyId])
}

model WorkflowRun {
  id         String    @id @default(uuid())
  workflowId String
  userId     String
  status     String    @default("running")
  logs       Json?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([workflowId])
}

// ─── Usage Metric (FR-17, FR-18) ──────────────────────

model UsageMetric {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  event     String
  module    String
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([module])
}

// ─── Support Ticket (FR-19) ───────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketChannel {
  CHAT
  EMAIL
  PHONE
  SELF_SERVICE
}

model SupportTicket {
  id        String        @id @default(uuid())
  companyId String
  userId    String
  channel   TicketChannel @default(CHAT)
  subject   String
  body      String        @db.Text
  status    TicketStatus  @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
}

// ─── Conversation / Chat Support ──────────────────────

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Conversation {
  id             String   @id @default(uuid())
  companyId      String
  createdById    String
  title          String?
  assistantType  String   @default("GENERAL")
  onboardingRole String? // 'general'|'sales'|'marketing'|'operations'|'product'|'finance'|'hr'
  brainProfileId String? // AI Brain used for this conversation
  brainVersionId String? // AI Brain version used
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id])
  createdBy User      @relation("ConversationCreator", fields: [createdById], references: [id])
  messages  Message[]

  @@index([companyId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─── Classification Type ──────────────────────────────

model ClassificationType {
  id               String   @id @default(uuid())
  companyId        String
  createdById      String
  name             String
  description      String?
  aiPrompt         String   @db.Text
  fieldDefinitions Json
  isTemplate       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company   Company                 @relation(fields: [companyId], references: [id])
  createdBy User                    @relation("ClassificationTypeCreator", fields: [createdById], references: [id])
  results   ClassificationResult[]
  history   ClassificationHistory[]

  @@index([companyId])
}

// ─── Classification Result ────────────────────────────

model ClassificationResult {
  id                   String   @id @default(uuid())
  companyId            String
  documentId           String
  classificationTypeId String
  extractedFields      Json
  confidence           Float?
  status               String   @default("completed")
  createdAt            DateTime @default(now())

  company            Company                 @relation(fields: [companyId], references: [id])
  document           Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)
  classificationType ClassificationType      @relation(fields: [classificationTypeId], references: [id])
  history            ClassificationHistory[]

  @@index([companyId])
  @@index([documentId])
  @@index([classificationTypeId])
}

// ─── Classification History ───────────────────────────

model ClassificationHistory {
  id                     String   @id @default(uuid())
  companyId              String
  userId                 String
  classificationTypeId   String
  classificationResultId String?
  action                 String
  feedback               String?
  metadata               Json?
  createdAt              DateTime @default(now())

  company            Company               @relation(fields: [companyId], references: [id])
  user               User                  @relation("ClassificationHistoryUser", fields: [userId], references: [id])
  classificationType ClassificationType    @relation(fields: [classificationTypeId], references: [id])
  result             ClassificationResult? @relation(fields: [classificationResultId], references: [id])

  @@index([companyId])
  @@index([userId])
}

