  MANUAL
  LEAD_DISCOVERY
  API
  IMPORT
}

enum CrmLeadLifecycleStatus {
  ACTIVE
  CONVERTED
  LOST
  ARCHIVED
}

model CrmLead {
  id              String                 @id @default(uuid())
  companyId       String
  ownerUserId     String?
  createdByUserId String
  pipelineStageId String
  sourceType      CrmLeadSourceType      @default(MANUAL)
  sourceReference String?
  leadName        String
  companyName     String?
  website         String?
  industry        String?
  location        String?
  email           String?
  phone           String?
  jobTitle        String?
  lifecycleStatus CrmLeadLifecycleStatus @default(ACTIVE)
  lostReason      String?
  notes           String?                @db.Text
  tags            Json?
  convertedAt     DateTime?
  archivedAt      DateTime?
  lastActivityAt  DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner         User?             @relation("CrmLeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy     User              @relation("CrmLeadCreator", fields: [createdByUserId], references: [id])
  pipelineStage CrmPipelineStage  @relation(fields: [pipelineStageId], references: [id])
  contacts      CrmLeadContact[]
  activities    CrmLeadActivity[]

  @@index([companyId])
  @@index([pipelineStageId])
  @@index([ownerUserId])
  @@index([companyId, lifecycleStatus])
}

// ─── CRM Lead Contact ─────────────────────────────────

model CrmLeadContact {
  id        String   @id @default(uuid())
  crmLeadId String
  name      String
  email     String?
  phone     String?
  jobTitle  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  lead CrmLead @relation(fields: [crmLeadId], references: [id], onDelete: Cascade)

  @@index([crmLeadId])
}

// ─── CRM Lead Activity ────────────────────────────────

model CrmLeadActivity {
  id        String   @id @default(uuid())
  crmLeadId String
  actorId   String
  action    String // note_added | stage_changed | owner_changed | created | updated | imported | lost | converted
  content   String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  lead  CrmLead @relation(fields: [crmLeadId], references: [id], onDelete: Cascade)
  actor User    @relation("CrmActivityActor", fields: [actorId], references: [id])

  @@index([crmLeadId, createdAt])
}

// ─── Assistant Skill ──────────────────────────────────

model AssistantSkill {
  id                 String   @id @default(uuid())
  companyId          String
  assistantType      String?  // @deprecated — kept for migration compat; use SkillAssignment instead
  key                String   // Unique slug: "linkedin_post", "prd", etc.
  name               String   // Display name: "LinkedIn Post"
  description        String?  @db.Text
  icon               String?  // Lucide icon name: "briefcase"
  category           String?  // Optional grouping: "social_media", "documentation"
  status             String   @default("ACTIVE") // ACTIVE | DRAFT | ARCHIVED
  executionType      String   @default("NATIVE") // NATIVE | ZAPIER_MCP | N8N_WORKFLOW | WEBHOOK
  executionConfig    Json?    // { mcpEndpoint, toolName } | { webhookUrl } | null for NATIVE
  sortOrder          Int      @default(0)
  isDefault          Boolean  @default(true) // System-provided vs user-created
  version            Int      @default(1)
  instructionPrompt  String?  @db.Text // Skill-specific AI instructions (the "program.md")
  outputSchema       Json?    // Structured output field definitions
  trainingMaterials  Json?    // Array of { id, filename, textContent, uploadedAt }
  requiredInputs     Json?    // What the user must provide
  defaultParams      Json?    // Default tone, length, etc.
  enabledActions     String[] @default([]) // IDs of ExternalAction records this skill can use
  outputActions      String[] @default(["preview", "copy", "regenerate"]) // Which output buttons to show: preview, copy, regenerate, render_ui, export_zip, export_md, export_pdf

  // ── ChatGPT-Compatible Runtime Metadata ──────────────
  importMode            String   @default("LEGACY")                 // LEGACY | PRESERVED | COMPATIBLE | DEGRADED
  runtimeCategory       String   @default("content-generation")     // content-generation | tool-orchestrated | artifact-generation | ui-rendering | connector-workflow | hybrid
  responseMode          String   @default("chat")                   // chat | artifact_first | artifact_plus_chat | ui_rendered | action_result | multi_output
  requiredCapabilities  String[] @default([])                       // slide_generation, image_generation, browsing, etc.
  requiredConnectors    String[] @default([])                       // IDs or slugs of required ExternalAction/Integration
  artifactContracts     Json?                                       // Expected artifact outputs: [{ type, mimeType, description }]
  uiContracts           Json?                                       // Expected UI behaviors: [{ intent, params }]
  compatibilityState    String   @default("UNKNOWN")                // FULLY_COMPATIBLE | COMPATIBLE_DEGRADED | INCOMPATIBLE | UNKNOWN
  degradationNotes      String?  @db.Text                           // What was lost during import/adaptation
  rawPackageRef         String?                                     // Storage path to original imported .zip/.md
  parsedManifest        Json?                                       // Full parsed manifest from import analysis

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments SkillAssignment[]
  brainProfiles BrainProfileSkill[]
  artifacts   SkillArtifact[]

  @@unique([companyId, key])
  @@index([companyId])
}

// ─── Skill Artifact (first-class runtime output) ──────

model SkillArtifact {
  id             String   @id @default(uuid())
  companyId      String
  skillId        String?  // FK to AssistantSkill (optional — may be ad-hoc)
  skillRunId     String   // ID from SkillRun table
  chainStepIndex Int?     // If produced during a chain step
  type           String   // presentation | document | spreadsheet | pdf | image | zip | chart | structured_ui
  mimeType       String   // application/vnd.openxmlformats-officedocument.presentationml.presentation, etc.
  filename       String   // my_deck.pptx
  storagePath    String   // Supabase Storage path
  sizeBytes      Int?
  previewUrl     String?  // Generated preview image URL
  metadata       Json?    // Extra artifact-specific metadata
  createdAt      DateTime @default(now())

  skill   AssistantSkill? @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([skillRunId])
  @@index([skillId])
}

// ─── Skill Assignment (many-to-many: Skill ↔ Team Member) ─

model SkillAssignment {
  id            String   @id @default(uuid())
  skillId       String
  assistantType String   // MARKETING | SALES | PRODUCT_ASSISTANT | ONBOARDING | COMPANY_ADVISOR | GENERAL_AI
  createdAt     DateTime @default(now())

  skill AssistantSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, assistantType])
  @@index([assistantType])
}

// ─── Skill Rating ─────────────────────────────────────

model SkillRating {
  id              String   @id @default(uuid())
  companyId       String
  skillKey        String   // Links to AssistantSkill.key
  assistantType   String   // MARKETING, SALES, etc. — context where rating was given
  generationRunId String   // ID from *GenerationRun table
  userId          String
  rating          Int      // 1 = thumbs down, 5 = thumbs up
  feedback        String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([companyId, skillKey])
  @@index([companyId, assistantType])
}

// ─── Skill Version Log ────────────────────────────────

model SkillVersionLog {
  id                String   @id @default(uuid())
  skillId           String   // FK to AssistantSkill.id
  version           Int
  instructionPrompt String?  @db.Text
  changedBy         String?  // userId
  changeSummary     String?
  createdAt         DateTime @default(now())

  @@index([skillId])
}

// ═══════════════════════════════════════════════════════
// COMPANY DNA — Structured Intelligence Layer
// ═══════════════════════════════════════════════════════

// ─── Company DNA ──────────────────────────────────────

model CompanyDNA {
  id              String    @id @default(uuid())
  companyId       String    @unique
  version         Int       @default(1)
  coverageScore   Float     @default(0)
  lastProcessedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nodes   KnowledgeNode[]
}

// ─── Knowledge Node ───────────────────────────────────

model KnowledgeNode {
  id                String   @id @default(uuid())
  companyId         String
  dnaId             String
  projectId         String?  // null = company-global knowledge
  customerId        String?  // null = not customer-specific
  type              String   // product | persona | process | competitor | messaging | policy
  title             String
  content           Json     // structured key-value pairs
  summary           String?  @db.Text // markdown for display
  confidenceScore   Float    @default(0.5)
  sourceDocumentIds String[] // Document / ExternalDocument IDs
  status            String   @default("active") // active | draft | archived
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dna       CompanyDNA     @relation(fields: [dnaId], references: [id], onDelete: Cascade)
  edgesFrom KnowledgeEdge[] @relation("EdgeFrom")
  edgesTo   KnowledgeEdge[] @relation("EdgeTo")

  @@index([companyId, type])
  @@index([dnaId])
  @@index([projectId])
  @@index([customerId])
}

// ─── Knowledge Edge ───────────────────────────────────

model KnowledgeEdge {
  id           String   @id @default(uuid())
  fromNodeId   String
  toNodeId     String
  relationType String   // targets | belongs_to | competes_with | requires | informs
  strength     Float    @default(0.5)
  createdAt    DateTime @default(now())

  fromNode KnowledgeNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   KnowledgeNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([fromNodeId])
  @@index([toNodeId])
}

// ─── Resource (Domain Grouping) ───────────────────────

model Resource {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  icon        String?  // lucide icon name
  nodeTypes   String[] // which node types belong here
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ─── Feedback Event ───────────────────────────────────

model FeedbackEvent {
  id              String    @id @default(uuid())
  companyId       String
  sourceType      String    // output_edit | manual_correction | approval | rejection
  originalContent String?   @db.Text
  editedContent   String?   @db.Text
  affectedNodeIds String[]
  status          String    @default("pending") // pending | processed | dismissed
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

// ═══════════════════════════════════════════════════════
// BOARDROOM — AI Team Orchestration Layer
// ═══════════════════════════════════════════════════════

// ─── Brain Profile ↔ Skill (per-member mapping) ──────

model BrainProfileSkill {
  id             String   @id @default(uuid())
  brainProfileId String
  skillId        String
  createdAt      DateTime @default(now())

  brain AIBrainProfile @relation(fields: [brainProfileId], references: [id], onDelete: Cascade)
  skill AssistantSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([brainProfileId, skillId])
  @@index([brainProfileId])
  @@index([skillId])
}

// ─── Plan Draft (editable before lock) ────────────────

model PlanDraft {
  id              String   @id @default(uuid())
  companyId       String
  projectId       String?
  command         String   @db.Text
  title           String
  objective       String   @db.Text
  successCriteria String?  @db.Text
  businessGoal    String?  @db.Text
  requestedOutcome String? @db.Text
  workType        String?
  confidenceScore Float?
  planSummary     String?  @db.Text
  workstreams     Json     // [{title, description}]
  tasks           Json     // [{title, description, purpose, deliverables, memberId, skillId, ...}]
  approvalGates   Json     // [{gateType, title, description, taskIndex}]
  executionMode   String   @default("MANUAL") // AUTO_CHAIN | MANUAL
  status          String   @default("DRAFT") // DRAFT | IN_REVIEW | REVISION | APPROVED | DISCARDED
  version         Int      @default(1)
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versions PlanDraftVersion[]

  @@index([companyId])
  @@index([companyId, status])
}

model PlanDraftVersion {
  id          String   @id @default(uuid())
  planDraftId String
  version     Int
  snapshot    Json     // full draft JSON blob at this point
  changeNote  String?  // "User edited task 3", "AI re-planned"
  createdAt   DateTime @default(now())

  planDraft PlanDraft @relation(fields: [planDraftId], references: [id], onDelete: Cascade)

  @@index([planDraftId])
}

// ─── Initiative ───────────────────────────────────────

model Initiative {
  id               String    @id @default(uuid())
  companyId        String
  projectId        String?
  planDraftId      String?   // FK → PlanDraft — trace back to original draft
  title            String
  objective        String    @db.Text
  businessGoal     String?   @db.Text
  requestedOutcome String?   @db.Text
  successCriteria  String?   @db.Text
  workType         String?   // website | campaign | lead_discovery | feature | content | custom
  confidenceScore  Float?
  status           String    @default("PLAN_DRAFT")
  // PLAN_DRAFT | PLAN_IN_REVIEW | PLAN_REVISION | PLAN_APPROVED | READY_FOR_EXECUTION | IN_PROGRESS | WAITING_HUMAN_INPUT | REVIEW_READY | COMPLETED | CANCELLED
  priority         String    @default("medium") // low | medium | high | urgent
  executionMode    String    @default("MANUAL") // AUTO_CHAIN | MANUAL — switchable mid-execution
  approvalMode     String    @default("MANUAL") // MANUAL | SEMI_AUTO | AUTO_LIMITED
  sourceCommand    String?   @db.Text // original user command
  planSummary      String?   @db.Text // AI-generated plan summary
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project     Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workstreams InitiativeWorkstream[]
  tasks       InitiativeTask[]
  approvals   ApprovalRequest[]
  events      InitiativeEvent[]
  artifacts   InitiativeArtifact[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([projectId])
}

// ─── Initiative Workstream ────────────────────────────

model InitiativeWorkstream {
  id           String   @id @default(uuid())
  initiativeId String
  title        String
  description  String?  @db.Text
  position     Int      @default(0)
  status       String   @default("NOT_STARTED")
  // NOT_STARTED | IN_PROGRESS | COMPLETED | BLOCKED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  initiative Initiative       @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  tasks      InitiativeTask[]

  @@index([initiativeId])
}

// ─── Initiative Task ──────────────────────────────────

model InitiativeTask {
  id               String    @id @default(uuid())
  initiativeId     String
  workstreamId     String?
  title            String
  description      String?   @db.Text
  purpose          String?   @db.Text  // why this task matters
  inputs           Json?     // what context/data is needed
  deliverables     Json?     // expected output description [{type, description}]
  acceptanceCriteria String? @db.Text  // what success looks like
  assignedBrainType String?  // MARKETING | SALES | PRODUCT_ASSISTANT | etc.
  assignedBrainId  String?   // FK to AIBrainProfile
  selectedSkillId  String?   // FK to AssistantSkill — the specific skill used for execution
  requiredSkill    String?   // @deprecated — use selectedSkillId
  status           String    @default("PLANNED")
  // PLANNED | READY_FOR_REVIEW | APPROVED_TO_RUN | RUNNING | OUTPUT_READY | NEEDS_REVISION | VALIDATED | BLOCKED | SKIPPED | CANCELLED
  position         Int       @default(0)
  dueTarget        DateTime?
  deliveredAt      DateTime?
  outputSummary    String?   @db.Text
  dependsOnTaskIds String[]  // array of InitiativeTask IDs
  executionModeOverride String? // AUTO_CHAIN | MANUAL | null (inherit from initiative)
  requiresApprovalBeforeRun Boolean @default(true)
  requiresApprovalAfterRun  Boolean @default(true)
  revisionCount    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  initiative Initiative            @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  workstream InitiativeWorkstream? @relation(fields: [workstreamId], references: [id], onDelete: SetNull)
  approvals  ApprovalRequest[]
  artifacts  InitiativeArtifact[]

  @@index([initiativeId])
  @@index([workstreamId])
  @@index([initiativeId, status])
}

// ─── Approval Request ─────────────────────────────────

model ApprovalRequest {
  id           String    @id @default(uuid())
  initiativeId String
  taskId       String?   // null = initiative-level approval
  gateType     String    // plan_approval | design_review | publish | deploy | outbound | budget | crm_import | destructive | client_facing | custom
  title        String
  description  String?   @db.Text
  status       String    @default("PENDING")
  // PENDING | APPROVED | REJECTED | REVISION_REQUESTED
  decidedById  String?
  decidedAt    DateTime?
  decisionNote String?   @db.Text
  createdAt    DateTime  @default(now())

  initiative Initiative      @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  task       InitiativeTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@index([initiativeId, status])
  @@index([taskId])
}

// ─── Initiative Event (Activity Log) ──────────────────

model InitiativeEvent {
  id           String   @id @default(uuid())
  initiativeId String
  actorType    String   // user | system | ai_member
  actorLabel   String?  // "Company DNA" | "Product Lead" | user name
  action       String   // created | planned | approved | rejected | started | completed | blocked | comment | artifact_added | revision_requested
  description  String?  @db.Text
  metadata     Json?
  createdAt    DateTime @default(now())

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@index([initiativeId, createdAt])
}

// ─── Initiative Artifact ──────────────────────────────

model InitiativeArtifact {
  id            String   @id @default(uuid())
  initiativeId  String
  taskId        String?
  artifactType  String   // prd | wireframe | content_draft | lead_list | campaign_plan | technical_plan | website_structure | implementation_plan | code | custom
  title         String
  content       String?  @db.Text
  contentUrl    String?  // link to external document/draft
  storageKey    String?  // Supabase storage path for uploaded files (images, etc.)
  sourceRunId   String?  // FK to *GenerationRun tables for traceability
  sourceRunType String?  // marketing_run | sales_run | product_run | etc.
  status        String   @default("DRAFT") // DRAFT | READY | APPROVED | SUPERSEDED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  initiative Initiative      @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  task       InitiativeTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([initiativeId])
  @@index([taskId])
}

// ─── Virtual Office ───────────────────────────────────

model VirtualOffice {
  id           String         @id @default(uuid())
  companyId    String         @unique
  name         String         @default("Office")
  layoutConfig Json?          // room positions, grid layout metadata
  template     String         @default("startup") // startup | team_pod | enterprise
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rooms        VirtualRoom[]
}

model VirtualRoom {
  id           String         @id @default(uuid())
  officeId     String
  name         String
  type         String         // PRIVATE_OFFICE | MEETING_ROOM | CONFERENCE_ROOM | OPEN_WORKSPACE | LOUNGE | KITCHEN
  capacity     Int            @default(8)
  privacy      String         @default("public") // public | team_only | invite_only | private_locked
  position     Json?          // { x, y, w, h } for grid layout
  isActive     Boolean        @default(true)
  createdBy    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  office       VirtualOffice  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  occupants    OfficePresence[]
  assignments  OfficeAssignment[]
  messages     RoomMessage[]

  @@index([officeId])
}

model OfficePresence {
  id           String         @id @default(uuid())
  userId       String
  companyId    String
  roomId       String?
  status       String         @default("online") // offline | online | in_office | in_room | in_call | dnd | away
  audioState   String         @default("muted")  // muted | unmuted
  videoState   String         @default("off")     // off | on
  lastSeenAt   DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  room         VirtualRoom?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([roomId])
}

model OfficeAssignment {
  id           String         @id @default(uuid())
  userId       String
  roomId       String
  role         String         @default("occupant") // occupant | owner
  teamId       String?
  createdAt    DateTime       @default(now())

  room         VirtualRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

model RoomMessage {
  id           String         @id @default(uuid())
  roomId       String
  userId       String
  content      String
  createdAt    DateTime       @default(now())

  room         VirtualRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

// ─── Daily Brief ──────────────────────────────────────

model DailyBrief {
  id            String   @id @default(uuid())
  companyId     String
  userId        String
  date          DateTime @db.Date
  briefText     String   @db.Text
  podcastScript String?  @db.Text
  audioUrl      String?
  audioDuration Int?
  sections      Json
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, date])
  @@index([companyId])
  @@index([userId])
}
