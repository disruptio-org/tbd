// ─── AI Brain Profile ─────────────────────────────────

model AIBrainProfile {
  id                   String   @id @default(uuid())
  companyId            String
  brainType            String // COMPANY | COMPANY_ADVISOR | SALES | MARKETING | ONBOARDING | LEAD_DISCOVERY
  name                 String
  description          String?  @db.Text
  parentBrainId        String?
  status               String   @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  isEnabled            Boolean  @default(true)
  configJson           Json // BrainConfig structured settings
  advancedInstructions Json? // BrainAdvancedInstructions
  createdById          String
  updatedById          String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User              @relation("BrainProfileCreator", fields: [createdById], references: [id])
  updatedBy   User              @relation("BrainProfileUpdater", fields: [updatedById], references: [id])
  parentBrain AIBrainProfile?   @relation("BrainParent", fields: [parentBrainId], references: [id])
  childBrains AIBrainProfile[]  @relation("BrainParent")
  versions    AIBrainVersion[]
  overrides   AIBrainOverride[]
  testRuns    AIBrainTestRun[]
  skills      BrainProfileSkill[]

  @@unique([companyId, brainType])
  @@index([companyId])
  @@index([parentBrainId])
}

