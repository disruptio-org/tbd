  @@index([brainProfileId])
  @@index([userId, status])
  @@index([companyId])
}

model AssistantMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String // USER | ASSISTANT | SYSTEM
  content   String   @db.Text
  inputMode String   @default("TEXT") // TEXT | VOICE
  metadata  Json?
  createdAt DateTime @default(now())

  session AssistantSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AssistantActionRun {
  id                   String   @id @default(uuid())
  sessionId            String
  companyId            String
  userId               String
  intentType           String // generate_content | create_task | search_leads | query_knowledge | navigate | summarize
  targetModule         String // marketing | sales | product | leads | knowledge | tasks | navigation
  targetAction         String?
  confidenceScore      Float?
  requiresConfirmation Boolean  @default(false)
  status               String   @default("PENDING") // PENDING | WAITING_CLARIFICATION | WAITING_CONFIRMATION | RUNNING | SUCCESS | PARTIAL_SUCCESS | FAILED | BLOCKED
  requestPayloadJson   Json?
  resultPayloadJson    Json?
  resultLink           String?
  groundingStatus      String? // VERIFIED | PARTIAL | NOT_FOUND
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  session AssistantSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([companyId])
  @@index([userId])
}

// ─── Artifacts (Generated Assets) ─────────────────────

model Artifact {
  id               String   @id @default(uuid())
  companyId        String
  sessionId        String
