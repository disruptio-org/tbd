}

model AssistantSession {
  id                 String    @id @default(uuid())
  userId             String
  companyId          String
  brainProfileId     String?   // FK to AIBrainProfile — scopes session to an AI member
  currentRoute       String?
  currentContextJson Json?
  status             String    @default("ACTIVE") // ACTIVE | COMPLETED | ABANDONED
  startedAt          DateTime  @default(now())
  endedAt            DateTime?

  messages   AssistantMessage[]
