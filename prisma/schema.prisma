  companyId   String
  projectId   String?
  name        String
  description String?  @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User              @relation("TaskBoardCreator", fields: [createdById], references: [id])
  columns   TaskBoardColumn[]
  tasks     Task[]

  @@index([companyId])
  @@index([projectId])
}

model TaskBoardColumn {
  id        String  @id @default(uuid())
  boardId   String
  name      String
  position  Int
  color     String?
  isDone    Boolean @default(false)
  isDefault Boolean @default(false)

  board TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

// ─── Task ─────────────────────────────────────────────

model Task {
  id              String    @id @default(uuid())
  companyId       String
  boardId         String
  columnId        String
  projectId       String?
  aiMemberId      String?   // FK to AIBrainProfile — assigns task to an AI member
  title           String
  description     String?   @db.Text
  priority        String    @default("medium") // low | medium | high | urgent
  position        Int       @default(0)
  startDate       DateTime?
  dueDate         DateTime?
  isCompleted     Boolean   @default(false)
  isHighlighted   Boolean   @default(false)
  estimatedEffort String?
  coverColor      String?
  coverImage      String?
  executionState  String   @default("NOT_STARTED") // NOT_STARTED | QUEUED | RUNNING | WAITING_ON_HUMAN | BLOCKED | READY_FOR_REVIEW | COMPLETED
  labels          Json? // string[]
  assigneeId      String?
  reporterId      String?
  sourceType      String? // MANUAL | CHAT_MESSAGE | DOCUMENT | KNOWLEDGE_GAP | PRODUCT_RUN | MARKETING_DRAFT | SALES_DRAFT | ONBOARDING_GUIDE | PROJECT | VOICE_AI | AI_MEMBER
  sourceEntityId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  board         TaskBoard       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column        TaskBoardColumn @relation(fields: [columnId], references: [id])
  assignee      User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter      User?           @relation("TaskReporter", fields: [reporterId], references: [id])
  comments      TaskComment[]
  activity      TaskActivity[]
  links         TaskLink[]
  checklists    TaskChecklist[]
  watchers      TaskWatcher[]
  taskDocuments TaskDocument[]

  @@index([companyId])
  @@index([boardId])
  @@index([columnId])
  @@index([assigneeId])
  @@index([aiMemberId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskCommenter", fields: [userId], references: [id])

  @@index([taskId])
}

model TaskActivity {
  id        String   @id @default(uuid())
  taskId    String
  actorId   String
  action    String // created | moved | assigned | priority_changed | commented | linked | updated | completed | checklist_added | label_changed | cover_changed | watched | copied
  metadata  Json? // e.g. { from: "To Do", to: "In Progress" }
  createdAt DateTime @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation("TaskActivityActor", fields: [actorId], references: [id])

  @@index([taskId, createdAt])
}

model TaskLink {
  id        String   @id @default(uuid())
  taskId    String
  linkType  String // document | conversation | message | knowledge_gap | product_run | marketing_draft | sales_draft | project | url
  entityId  String?
  url       String?
  label     String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

